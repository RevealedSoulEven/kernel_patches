+static bool reader_is_user_app(void)
+{
+    kuid_t uid = current_uid();
+    return (__kuid_val(uid) >= USER_APP_UID_MIN);
+}
+
+/*
+ * Return true if we should hide this VMA from the current reader.
+ * Only runs hiding logic when the reader is a (Android) user app UID >= USER_APP_UID_MIN.
+ * Uses d_name.name for short-name matching. If you need full-path checks use d_path()
+ * with a bounded buffer (but be careful about reentrancy and allocation constraints).
+ */
+static bool should_hide_vma_for_reader(struct vm_area_struct *vma)
+{
+    struct file *file;
+    const char *name;
+    vm_flags_t flags;
+
+    if (!vma)
+        return false;
+
+    /* Only hide when the reader is a user app */
+    if (!reader_is_user_app())
+        return false;
+
+    file = vma->vm_file;
+    flags = vma->vm_flags;
+    if (!file || !file->f_path.dentry)
+        return false;
+
+    name = file->f_path.dentry->d_name.name;
+    if (!name)
+        return false;
+
+    /* Hide frida agent/memfd artifacts */
+    if (strstr(name, "frida-"))
+        return true;
+    if (!strncmp(name, "memfd:", 6) && strstr(name, "frida"))
+        return true;
+        
+    if (strstr(name, "libart.so") && (flags & VM_EXEC))
+        return true;
+
+    /* Hide known LSPosed/Xposed artifacts (example names) */
+    if (strstr(name, "liblsposed") || strstr(name, "libxposed_art") || strstr(name, "libxposed") || strstr(name, "xposed"))
+        return true;
+
+    /*
+     * Important: DO NOT hide libart.so or generic VM_EXEC mappings.
+     * Hiding libart.so or relabeling all exec regions as [vdso] breaks zygote/ART/JIT.
+     */
+    return false;
+}
